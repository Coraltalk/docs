{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Coraltalk AI",
  "colors": {
    "primary": "#0E7490",
    "light": "#22D3EE",
    "dark": "#0E7490"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart-coraltalk",
              "getting-started/introduction",
              "getting-started/for-teachers",
              "getting-started/for-students"
            ]
          },
          {
            "group": "Teaching Assistant",
            "pages": [
              "teaching-assistant/customize-ta"
            ]
          },
          {
            "group": "Assessments",
            "pages": [
              "assessments/oral-assignments"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/canvas-integration"
            ]
          },
          {
            "group": "Help & Troubleshooting",
            "pages": [
              "troubleshooting/common-issues"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Release Notes",
            "pages": [
              "changelog/releases"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "What's New",
          "href": "/changelog/releases",
          "icon": "sparkles"
        },
        {
          "anchor": "Book a demo",
          "href": "https://coraltalk.com/demo-req",
          "icon": "calendar"
        },
        {
          "anchor": "Go to app",
          "href": "https://coraltalk.com",
          "icon": "arrow-up-right-from-square"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@coraltalk.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try for free",
      "href": "https://app.coraltalk.com/signup"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/coraltalk-ai",
      "instagram": "https://www.instagram.com/coraltalk_ai"
    }
  },
  "footerSocials": {
    "linkedin": "https://www.linkedin.com/company/coraltalk-ai",
    "instagram": "https://www.instagram.com/coraltalk_ai"
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  }
}
